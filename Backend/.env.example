NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/multistore
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_ORIGIN=*
REFRESH_COOKIE_NAME=refreshToken

# Stripe (optional - required only when using paymentMethod=online)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3000/checkout/success
STRIPE_CANCEL_URL=http://localhost:3000/checkout/cancel
PLATFORM_CURRENCY=usd

# Google Maps Geocoding API (required for address/postcode → store discovery)
# Get your key: https://console.cloud.google.com → Enable "Geocoding API"
# $200/month free credit (~40,000 geocode calls/month)
GOOGLE_MAPS_API_KEY=
